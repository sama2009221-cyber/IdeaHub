# ==========================================
# IdeaHub Backend — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────
# AI — Groq API Key (REQUIRED)
# Get your free key at: https://console.groq.com
# ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────
# Django Core
# ──────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True

# ──────────────────────────────────────────
# Optional: Restrict registration to company email domain
# Example: ALLOWED_EMAIL_DOMAIN=mycompany.com
# ──────────────────────────────────────────
# ALLOWED_EMAIL_DOMAIN=
